# LLM Configuration
LLM_PROVIDER=openai          # openai | anthropic
LLM_MODEL=gpt-4o             # Model name
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# Exchange Configuration
EXCHANGE_MODE=mock            # mock | live
EXCHANGE_NAME=binance         # binance | okx | bybit
EXCHANGE_API_KEY=
EXCHANGE_SECRET=
EXCHANGE_PASSWORD=            # Some exchanges require a passphrase

# Trading Configuration
TRADING_SYMBOL=BTC/USDT
TRADING_TIMEFRAME=1h
MAX_POSITION_SIZE=1.0         # Maximum position size in base currency
MAX_DRAWDOWN_PCT=10.0         # Maximum drawdown percentage before risk alert
MAX_ITERATIONS=10             # Maximum trading loop iterations

# Logging
LOG_LEVEL=INFO
