# LLM Configuration
LLM_PROVIDER=openai          # openai | anthropic
LLM_MODEL=gpt-4o             # Model name
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# Workspace
WORKSPACE_ROOT=./my_workspace   # 用户 Workspace 根路径

# Workflow
MAX_ITERATIONS=5              # 最大循环次数

# Web UI
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Logging
LOG_LEVEL=INFO
